# Salesforce Developer Edition
# Newer Agentforce orgs require OAuth (SOAP login is blocked). To use OAuth
# Username-Password flow, create an External Client App with the
# "authorization code and login credentials" flow enabled, then paste the
# Consumer Key and Consumer Secret below. Older orgs can leave them empty
# (code falls back to legacy SOAP auth).
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_DOMAIN=login
SF_CONSUMER_KEY=
SF_CONSUMER_SECRET=

# Stripe (test mode only — never paste a live secret here)
STRIPE_SECRET_KEY=sk_test_

# HubSpot Developer (Private App access token)
HUBSPOT_ACCESS_TOKEN=pat-
HUBSPOT_PORTAL_ID=

# GCP / BigQuery (reused from earlier)
GCP_PROJECT_ID=truthkeeper-hack-2026
BQ_DATASET=truthkeeper_demo

# Reconciliation reference date — "today" for the seed.
# Discrepancy ages (23 days ago, last Friday, etc.) are computed off this.
SEED_BASE_DATE=2026-05-19
